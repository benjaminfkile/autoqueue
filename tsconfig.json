{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2019",
    "lib": ["es2022", "dom"],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "strict": true,
    "outDir": "dist"
  },
  "include": ["src", "index.ts"],
  "exclude": ["dist", "node_modules"]
}
